---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, tags } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="post-header">
					<div class="post-meta">
						<span class="post-date"><FormattedDate date={pubDate} /></span>
						{tags && tags.map((tag: string) => (
							<span class="tag">{tag}</span>
						))}
					</div>
					<h1>{title}</h1>
					{description && <p class="description">{description}</p>}
					{updatedDate && (
						<p class="updated">Updated: <FormattedDate date={updatedDate} /></p>
					)}
					<hr />
				</div>
				<div class="prose">
					<slot />
				</div>
				<div class="back-link">
					<a href="/blog">← Back to Guides</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 760px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 3em 1em;
	}
	.post-header {
		margin-bottom: 2em;
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.6em;
		margin-bottom: 0.75em;
	}
	.post-date {
		font-size: 0.85em;
		color: var(--text-muted);
	}
	.tag {
		font-size: 0.72em;
		padding: 0.15em 0.55em;
		background: rgba(88, 166, 255, 0.12);
		color: var(--accent);
		border-radius: 99px;
		font-weight: 500;
	}
	h1 {
		font-size: 2.2em;
		margin: 0 0 0.4em 0;
		line-height: 1.2;
	}
	.description {
		font-size: 1.1em;
		color: var(--text-muted);
		margin: 0 0 0.75em 0;
	}
	.updated {
		font-size: 0.85em;
		color: var(--text-muted);
		font-style: italic;
		margin: 0.5em 0 0 0;
	}
	hr {
		margin-top: 1.5em;
	}
	.prose {
		line-height: 1.8;
	}
	.prose h2 {
		margin-top: 2em;
		padding-top: 1em;
		border-top: 1px solid var(--bg-border);
	}
	.prose h3 {
		margin-top: 1.5em;
	}
	.prose ul, .prose ol {
		margin-bottom: 1.5em;
	}
	.prose li {
		margin-bottom: 0.5em;
	}
	.back-link {
		margin-top: 3em;
		padding-top: 1.5em;
		border-top: 1px solid var(--bg-border);
	}
	.back-link a {
		color: var(--text-muted);
		font-size: 0.9em;
	}
	.back-link a:hover {
		color: var(--accent);
	}
</style>
