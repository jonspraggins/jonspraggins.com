---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span>© {today.getFullYear()} Jon Spraggins — <em>Fully depreciated but still in production.</em></span>
		<a href="/rss.xml" aria-label="RSS Feed">RSS</a>
	</div>
</footer>

<style>
	footer {
		padding: 2em 1.5em;
		border-top: 1px solid var(--bg-border);
		color: var(--text-muted);
		font-size: 0.875em;
	}
	.footer-inner {
		max-width: 760px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1em;
		flex-wrap: wrap;
	}
	a {
		color: var(--text-muted);
		text-decoration: none;
	}
	a:hover {
		color: var(--accent);
	}
</style>
