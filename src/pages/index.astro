---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>The Idiot's Guide</h1>
				<p class="tagline">A homelab tinkerer's notes on tech, hardware, and security. Learning in public — mistakes and all.</p>
			</section>

			<section class="posts">
				<h2 class="section-label">Guides</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`} class="post-card">
								<div class="post-meta">
									<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
									{post.data.tags && post.data.tags.map((tag: string) => (
										<span class="tag">{tag}</span>
									))}
								</div>
								<h3 class="post-title">{post.data.title}</h3>
								<p class="post-description">{post.data.description}</p>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-bottom: 3em;
		padding-bottom: 2em;
		border-bottom: 1px solid var(--bg-border);
	}
	.hero h1 {
		font-size: 2.8em;
		margin-bottom: 0.4em;
	}
	.tagline {
		color: var(--text-muted);
		font-size: 1.1em;
		margin: 0;
	}
	.section-label {
		font-size: 0.8em;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		margin-bottom: 1.25em;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1px;
	}
	.post-card {
		display: block;
		padding: 1.25em 1.5em;
		background: var(--bg-surface);
		border: 1px solid var(--bg-border);
		border-radius: 8px;
		margin-bottom: 0.75em;
		text-decoration: none;
		transition: border-color 0.15s, background 0.15s;
	}
	.post-card:hover {
		border-color: var(--accent);
		background: rgba(88, 166, 255, 0.05);
		text-decoration: none;
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.6em;
		margin-bottom: 0.4em;
	}
	.post-date {
		font-size: 0.8em;
		color: var(--text-muted);
	}
	.tag {
		font-size: 0.72em;
		padding: 0.15em 0.55em;
		background: rgba(88, 166, 255, 0.12);
		color: var(--accent);
		border-radius: 99px;
		font-weight: 500;
	}
	.post-title {
		font-size: 1.15em;
		margin: 0 0 0.35em 0;
		color: var(--text-heading);
	}
	.post-description {
		font-size: 0.9em;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.5;
	}
</style>
